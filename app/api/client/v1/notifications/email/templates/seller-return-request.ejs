<h1 style="margin:0 0 16px;font-size:24px;line-height:1.3;color:#202020;">A return request needs your attention</h1>
<p style="margin:0 0 14px;color:#4b5563;font-size:15px;line-height:1.7;">
  A customer submitted a return request for order <strong><%= orderNumber %></strong>.
</p>
<p style="margin:0 0 14px;color:#4b5563;font-size:15px;line-height:1.7;">
  Return reference: <strong><%= returnId %></strong><br/>
  Reason: <strong><%= reason %></strong>
</p>
<% if (message) { %>
  <p style="margin:0 0 14px;color:#4b5563;font-size:15px;line-height:1.7;">
    Customer message: <%= message %>
  </p>
<% } %>
<% if (Array.isArray(items) && items.length) { %>
  <p style="margin:0 0 8px;color:#202020;font-size:14px;font-weight:600;">Affected items</p>
  <ul style="margin:0 0 16px 18px;padding:0;color:#4b5563;font-size:14px;line-height:1.7;">
    <% items.forEach(function(item){ %>
      <li><%= item.productTitle %><% if (item.variantLabel) { %> — <%= item.variantLabel %><% } %> x <%= item.quantity %></li>
    <% }) %>
  </ul>
<% } %>
<p style="margin:0;color:#4b5563;font-size:15px;line-height:1.7;">
  Please review the request in your seller tools and follow the correct return process for this fulfilment method.
</p>
