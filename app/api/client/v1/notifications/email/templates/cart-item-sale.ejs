<p style="margin:0 0 16px;font-size:16px;line-height:1.6;color:#202020;">
  Hi <%= customerName || "there" %>,
</p>

<p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#57636c;">
  One or more items in your cart just dropped in price.
</p>

<% (Array.isArray(items) ? items : []).forEach(function(item){ %>
  <div style="margin:0 0 16px;padding:16px;border:1px solid rgba(20,24,27,0.08);border-radius:8px;">
    <p style="margin:0 0 6px;font-size:15px;font-weight:600;color:#202020;">
      <%= item.productTitle %><% if (item.variantLabel) { %> · <%= item.variantLabel %><% } %>
    </p>
    <p style="margin:0 0 6px;font-size:14px;color:#57636c;">
      Was <span style="text-decoration:line-through;"><%= item.previousPrice %></span>
      and is now <strong style="color:#1a8553;"><%= item.salePrice %></strong>.
    </p>
    <% if (item.productUrl) { %>
      <p style="margin:0;">
        <a href="<%= item.productUrl %>" style="color:#0049ff;text-decoration:underline;">View item</a>
      </p>
    <% } %>
  </div>
<% }) %>

<p style="margin:0;font-size:14px;line-height:1.6;color:#57636c;">
  Your cart has already been updated with the latest price.
</p>
