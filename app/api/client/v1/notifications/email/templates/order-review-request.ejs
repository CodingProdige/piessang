<div style="font-family:Arial,sans-serif;color:#202020;line-height:1.6;">
  <p style="margin:0 0 14px;">Hi <%= customerName || "there" %>,</p>
  <p style="margin:0 0 14px;">
    Your order <strong><%= orderNumber || "" %></strong> is now complete.
  </p>
  <p style="margin:0 0 14px;">
    You can now leave a review for the seller and review any of the products you bought.
  </p>
  <p style="margin:20px 0 10px;">
    <a href="<%= orderUrl %>" style="display:inline-block;padding:12px 18px;border-radius:10px;background:#202020;color:#ffffff;text-decoration:none;font-weight:600;">
      View order
    </a>
  </p>
  <p style="margin:0 0 10px;">
    You can also manage your product reviews here:
  </p>
  <p style="margin:0 0 14px;">
    <a href="<%= reviewsUrl %>" style="color:#0f80c3;text-decoration:underline;">Open your product reviews</a>
  </p>
  <p style="margin:18px 0 0;color:#57636c;">
    Thanks for shopping on Piessang.
  </p>
</div>
