<h2><%= statusHeading || "Product status update" %></h2>

<p>Hi <%= vendorName %>,</p>

<p>
<% if (isLiveUpdate) { %>
Your latest changes for <strong><%= productTitle %></strong> have changed status on Piessang.
<% } else { %>
Your product <strong><%= productTitle %></strong> has changed status on Piessang.
<% } %>
</p>

<ul>
  <li><strong>Status:</strong> <%= statusLabel %></li>
  <li><strong>Fulfilment:</strong> <%= fulfillmentLabel %></li>
  <% if (reason) { %>
    <li><strong>Reason:</strong> <%= reason %></li>
  <% } %>
</ul>

<p>
<%= nextStep %>
</p>

<p style="margin-top: 20px;">
Cheers,<br/>
The Piessang Team
</p>
